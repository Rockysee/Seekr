# Rename this file to .env and populate with real secrets.
# Do NOT commit .env to source control.

# Core
APP_NAME="Resilience Matrix"
ENV=development
DEBUG=true

# Encryption (required in production)
# Generate a secure key and store it safely (e.g., Vault, AWS KMS)
RESILIENCE_MASTER_KEY="<your-base64-fernet-key>"

# Make.com orchestration
MAKE_COM_WEBHOOK_URL="https://hook.make.com/<your-scenario-id>"

# Tele-MANAS integration
TELE_MANAS_API_URL="https://telemanas.health.gov.in/api"
TELE_MANAS_API_KEY="<your-tele-manas-api-key>"

# WhatsApp Business (optional)
WHATSAPP_PHONE_NUMBER_ID="<your-phone-number-id>"
WHATSAPP_ACCESS_TOKEN="<your-access-token>"
WHATSAPP_BUSINESS_ACCOUNT_ID="<your-business-account-id>"
